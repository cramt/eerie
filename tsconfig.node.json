{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".",
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*.ts",
    "src/codegen/**/*.ts",
    "src/preload/**/*.ts",
  ],
}
