# Do NOT add src/renderer/src/types/generated.ts to .gitignore.

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Nix
.direnv/
result

# Old circuit format (superseded by project directories with .yaml files)
*.eerie

# Project manifests and circuits at the repo root (auto-created by daemon)
/eerie.yaml
/*.yaml

# Logs
*.log
npm-debug.log*

# Test artifacts
*.snap

# Playwright e2e screenshots (generated, not committed)
e2e/screenshots/*.png

# TypeScript incremental build info
*.tsbuildinfo

# Flatpak generated sources (large, regenerated by flatpak/generate-sources.sh)
flatpak/cargo-sources.json
flatpak/node-sources.json
flatpak/eerie-wasm.tar.gz
